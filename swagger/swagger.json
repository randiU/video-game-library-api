      }
    }
  },
  "components": {
    "schemas": {
      "GameInput": {
        "type": "object",
        "required": [
          "title",
          "description",
          "developer",
          "publisher",
          "releaseYear",
          "genre",
          "platforms",
          "playerCount",
          "multiplayer",
          "ageRating",
          "gameStyle"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "The Legend of Zelda: Breath of the Wild"
          },
          "description": {
            "type": "string",
            "example": "An open-world adventure game focused on exploration and puzzle solving."
          },
          "developer": {
            "type": "string",
            "example": "Nintendo"
          },
          "publisher": {
            "type": "string",
            "example": "Nintendo"
          },
          "releaseYear": {
            "type": "number",
            "example": 2017
          },
          "genre": {
            "type": "string",
            "example": "Action-adventure"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Nintendo Switch",
              "Wii U"
            ]
          },
          "playerCount": {
            "type": "string",
            "example": "1"
          },
          "multiplayer": {
            "type": "boolean",
            "example": false
          },
          "ageRating": {
            "type": "string",
            "example": "E10+"
          },
          "gameStyle": {
            "type": "string",
            "example": "Open world"
          },
          "averageRating": {
            "type": "number",
            "example": 9.7
          }
        }
      },
      "GenreInput": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "action",
              "adventure",
              "action-adventure",
              "rpg",
              "strategy",
              "simulation",
              "sports",
              "racing",
              "puzzle",
              "platformer",
              "shooter",
              "fighting",
              "horror",
              "sandbox",
              "party",
              "educational"
            ],
            "example": "action-adventure"
          },
          "description": {
            "type": "string",
            "example": "Games that combine action gameplay with exploration, story, and adventure elements."
          }
        }
      },
      "PlatformInput": {
        "type": "object",
        "required": [
          "name",
          "manufacturer",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "nintendo switch",
              "playstation 5",
              "playstation 4",
              "xbox series x/s",
              "xbox one",
              "pc",
              "mobile",
              "steam deck"
            ],
            "example": "nintendo switch"
          },
          "manufacturer": {
            "type": "string",
            "enum": [
              "nintendo",
              "sony",
              "microsoft",
              "valve",
              "apple",
              "google",
              "various"
            ],
            "example": "nintendo"
          },
          "description": {
            "type": "string",
            "example": "A hybrid home and handheld gaming console from Nintendo."
          }
        }
      }
    }
  }
}
