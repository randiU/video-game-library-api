{
  "openapi": "3.0.0",
  "info": {
    "title": "Video Game Library API",
    "version": "1.0.0",
    "description": "API documentation for the Video Game Library and Review API.\n\n## Authentication\n\nThis API uses Google OAuth. Log in by opening **[/auth/google](/auth/google)** in your browser (the Swagger \"Try it out\" button cannot follow the redirect to Google). After logging in you'll be returned here, and protected routes (POST/PUT/DELETE) will work via your session cookie.\n\n- **[Log in with Google](/auth/google)**\n- **[Check login status](/auth/status)**\n- **[Log out](/auth/logout)**"
  },
  "servers": [
    {
      "url": "https://video-game-library-api-2rcc.onrender.com",
      "description": "Render production server"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "General",
      "description": "General API status and information."
    },
    {
      "name": "Auth",
      "description": "Google OAuth login, logout, and session status."
    },
    {
      "name": "Users",
      "description": "Operations on registered user accounts."
    },
    {
      "name": "Games",
      "description": "Operations on the video game catalog."
    },
    {
      "name": "Genres",
      "description": "Operations on video game genres."
    },
    {
      "name": "Platforms",
      "description": "Operations on gaming platforms."
    },
    {
      "name": "Reviews",
      "description": "Operations for user game reviews and ratings."
    }
  ],
  "paths": {
    "/auth/google": {
      "get": {
        "tags": ["Auth"],
        "summary": "Start Google login",
        "description": "Redirects the browser to Google's OAuth consent screen. Open this URL directly in a browser; it cannot be tested with the Swagger 'Try it out' button because it issues a redirect.",
        "responses": {
          "302": {
            "description": "Redirect to Google for authentication."
          }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "Google OAuth callback",
        "description": "Google redirects here after the user approves access. On success the user is logged in and redirected to /api-docs.",
        "responses": {
          "302": {
            "description": "Redirect to /api-docs on success, or /auth/failure on failure."
          }
        }
      }
    },
    "/auth/status": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current login status",
        "description": "Returns whether the current session is authenticated and, if so, the logged-in user.",
        "responses": {
          "200": {
            "description": "Authentication status returned successfully."
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": ["Auth"],
        "summary": "Log out",
        "description": "Ends the current session and clears the session cookie.",
        "responses": {
          "200": {
            "description": "Logged out successfully."
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Get all users",
        "description": "Returns all registered user accounts.",
        "responses": {
          "200": {
            "description": "Users returned successfully."
          },
          "500": {
            "description": "Failed to get users."
          }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create a user",
        "description": "Creates a user account. Users are normally created automatically through Google OAuth; this route completes the CRUD set. Requires authentication.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully."
          },
          "400": {
            "description": "Invalid user data."
          },
          "401": {
            "description": "Authentication required."
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get a user by ID",
        "description": "Returns one user account by MongoDB ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ID of the user.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User returned successfully."
          },
          "400": {
            "description": "Invalid user ID format."
          },
          "404": {
            "description": "User not found."
          },
          "500": {
            "description": "Failed to get user."
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update a user",
        "description": "Updates one user account by MongoDB ID. Requires authentication.",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ID of the user.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully."
          },
          "400": {
            "description": "Invalid user ID or invalid user data."
          },
          "401": {
            "description": "Authentication required."
          },
          "404": {
            "description": "User not found."
          },
          "500": {
            "description": "Failed to update user."
          }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete a user",
        "description": "Deletes one user account by MongoDB ID. Requires authentication.",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ID of the user.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully."
          },
          "400": {
            "description": "Invalid user ID format."
          },
          "401": {
            "description": "Authentication required."
          },
          "404": {
            "description": "User not found."
          },
          "500": {
            "description": "Failed to delete user."
          }
        }
      }
    },
    "/": {
      "get": {
        "tags": ["General"],
        "summary": "API home route",
        "description": "Confirms that the Video Game Library API is running.",
        "responses": {
          "200": {
            "description": "API is running successfully."
          }
        }
      }
    },
