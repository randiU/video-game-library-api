{
  "openapi": "3.0.0",
  "info": {
    "title": "Video Game Library API",
    "version": "1.0.0",
    "description": "API documentation for the Video Game Library and Review API"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "API home route",
        "description": "Confirms that the Video Game Library API is running.",
        "responses": {
          "200": {
            "description": "API is running successfully."
          }
        }
      }
    },
    "/games": {
      "get": {
        "summary": "Get all games",
        "description": "Returns all video game records.",
        "responses": {
          "200": {
            "description": "Games returned successfully."
          },
          "500": {
            "description": "Failed to get games."
          }
        }
      },
      "post": {
        "summary": "Create a game",
        "description": "Creates a new video game record.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GameInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Game created successfully."
          },
          "400": {
            "description": "Invalid game data."
          }
        }
      }
    },
    "/games/{id}": {
      "get": {
        "summary": "Get a game by ID",
        "description": "Returns one video game record by MongoDB ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ID of the game.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Game returned successfully."
          },
          "400": {
            "description": "Invalid game ID format."
          },
          "404": {
            "description": "Game not found."
          },
          "500": {
            "description": "Failed to get game."
          }
        }
      },
      "put": {
        "summary": "Update a game",
        "description": "Updates one video game record by MongoDB ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ID of the game.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GameInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Game updated successfully."
          },
          "400": {
            "description": "Invalid game ID or invalid game data."
          },
          "404": {
            "description": "Game not found."
          },
          "500": {
            "description": "Failed to update game."
          }
        }
      },
      "delete": {
        "summary": "Delete a game",
        "description": "Deletes one video game record by MongoDB ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ID of the game.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Game deleted successfully."
          },
          "400": {
            "description": "Invalid game ID format."
          },
          "404": {
            "description": "Game not found."
          },
          "500": {
            "description": "Failed to delete game."
          }
        }
      }
    },
