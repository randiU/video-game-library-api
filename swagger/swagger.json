    "/reviews": {
      "get": {
       "tags": ["Reviews"],
       "summary": "Get all reviews",
        "description": "Returns all reviews with user and game references populated.",
       "responses": {
          "200": {
           "description": "Reviews returned successfully."
         },
          "500": {
            "description": "Failed to get reviews."
         }
       }
     },
      "post": {
        "tags": ["Reviews"],
       "summary": "Create a review",
       "description": "Creates a new review. Requires authentication.",
       "security": [{ "cookieAuth": [] }],
       "requestBody": {
          "required": true,
          "content": {
           "application/json": {
             "schema": {
               "type": "object",
                "required": ["gameId", "rating"],
               "properties": {
                  "gameId": {
                    "type": "string"
                 },
                 "rating": {
                   "type": "number",
                    "minimum": 1,
                    "maximum": 5
                 },
                 "reviewText": {
                   "type": "string"
                 },
                 "recommend": {
                   "type": "boolean"
                  }   
                }
              }
            }
         }
       },
       "responses": {
         "201": {
           "description": "Review created successfully."
         },
         "400": {
            "description": "Invalid review data."
         },
         "401": {
           "description": "Authentication required."
         }
       }
     }
    },
    "/reviews/{id}": {
      "get": {
       "tags": ["Reviews"],
        "summary": "Get review by ID",
       "parameters": [
         {
           "name": "id",
           "in": "path",
            "required": true,
            "schema": {
              "type": "string"
           }
         }
       ],
        "responses": {
          "200": {
           "description": "Review returned successfully."
         },
         "400": {
            "description": "Invalid review ID format."
          },
          "404": {
           "description": "Review not found."
          }
        }
     },
     "put": {
       "tags": ["Reviews"],
       "summary": "Update a review",
       "security": [{ "cookieAuth": [] }],
        "parameters": [
         {
            "name": "id",
           "in": "path",
           "required": true,
            "schema": {
              "type": "string"
            }
         }
       ],
       "requestBody": {
          "required": true,
         "content": {
           "application/json": {
             "$ref": "#/components/schemas/Review"
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review updated successfully."
          },
         "400": {
            "description": "Invalid data."
          },
         "404": {
            "description": "Review not found."
          }
       }
      },
     "delete": {
       "tags": ["Reviews"],
        "summary": "Delete a review",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
           }
         }
        ],
       "responses": {
          "200": {
            "description": "Review deleted successfully."
         },
          "400": {
            "description": "Invalid review ID format."
          },
          "404": {
            "description": "Review not found."
          }
        }
     }
    }

  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "connect.sid",
        "description": "Session cookie set after logging in via Google OAuth at /auth/google."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "665f1b2c9d3e4a0012ab34cd"
          },
          "googleId": {
            "type": "string",
            "example": "118273645019283746500"
          },
          "displayName": {
            "type": "string",
            "example": "Jane Gamer"
          },
          "email": {
            "type": "string",
            "example": "jane.gamer@example.com"
          },
          "role": {
            "type": "string",
            "enum": ["user", "admin"],
            "example": "user"
          },
          "Review": {
            "type": "object",
            "properties": {
              "_id": {
                "type": "string",
                "example": "665f1b2c9d3e4a0012ab34cd"
              },
              "userId": {
                "type": "string",
                "example": "665f1b2c9d3e4a0012ab34aa"
              },
              "gameId": {
                "type": "string",
                "example": "665f1b2c9d3e4a0012ab34bb"
              },
             "rating": {
               "type": "number",
                "minimum": 1,
                "maximum": 5,
                "example": 5
              },
              "reviewText": {
                "type": "string",
                "example": "Amazing game!"
              },
             "recommend": {
               "type": "boolean",
               "example": true
             },
              "createdAt": {
               "type": "string",
                "format": "date-time"
             },
             "updatedAt": {
                "type": "string",
               "format": "date-time"
             }
            }
          }
        }
      },
      "UserInput": {
        "type": "object",
        "required": ["googleId", "displayName", "email"],
        "properties": {
          "googleId": {
            "type": "string",
            "example": "118273645019283746500"
          },
          "displayName": {
            "type": "string",
            "example": "Jane Gamer"
          },
          "email": {
            "type": "string",
            "example": "jane.gamer@example.com"
          },
          "role": {
            "type": "string",
            "enum": ["user", "admin"],
            "example": "user"
          }
        }
      },
      "GameInput": {
        "type": "object",
        "required": [
          "title",
          "description",
          "developer",
          "publisher",
          "releaseYear",
          "genre",
          "platforms",
          "playerCount",
          "multiplayer",
          "ageRating",
          "gameStyle"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "The Legend of Zelda: Breath of the Wild"
          },
          "description": {
            "type": "string",
            "example": "An open-world adventure game focused on exploration and puzzle solving."
          },
          "developer": {
            "type": "string",
            "example": "Nintendo"
          },
          "publisher": {
            "type": "string",
            "example": "Nintendo"
          },
          "releaseYear": {
            "type": "number",
            "example": 2017
          },
          "genre": {
            "type": "string",
            "example": "Action-adventure"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Nintendo Switch",
              "Wii U"
            ]
          },
          "playerCount": {
            "type": "string",
            "example": "1"
          },
          "multiplayer": {
            "type": "boolean",
            "example": false
          },
          "ageRating": {
            "type": "string",
            "example": "E10+"
          },
          "gameStyle": {
            "type": "string",
            "example": "Open world"
          },
          "averageRating": {
            "type": "number",
            "example": 9.7
          }
        }
      },
      "GenreInput": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "action",
              "adventure",
              "action-adventure",
              "rpg",
              "strategy",
              "simulation",
              "sports",
              "racing",
              "puzzle",
              "platformer",
              "shooter",
              "fighting",
              "horror",
              "sandbox",
              "party",
              "educational"
            ],
            "example": "action-adventure"
          },
          "description": {
            "type": "string",
